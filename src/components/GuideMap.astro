---
const { interactive = false } = Astro.props;
---
<div class:list={["guide-map", { interactive }]}>
  <svg viewBox="0 0 800 460" role="img" aria-labelledby="map-title map-desc">
    <title id="map-title">北港老街步行關係示意圖</title>
    <desc id="map-desc">顯示朝天宮、中山路、工藝坊、遊客中心、水道頭、女兒橋、停車區與公廁的相對位置，非精確比例地圖。</desc>
    <defs><pattern id="grid" width="36" height="36" patternUnits="userSpaceOnUse"><path d="M36 0H0v36" fill="none" stroke="#7a4b38" stroke-opacity=".08"/></pattern></defs>
    <rect width="800" height="460" rx="24" fill="#efe1cc"/>
    <rect width="800" height="460" rx="24" fill="url(#grid)"/>
    <path d="M35 400C160 328 230 358 360 410S650 450 800 360v100H0z" fill="#89aaa1"/>
    <path d="M40 330h720M155 50v310M295 40v340M500 50v340M670 70v310" fill="none" stroke="#d7c5ae" stroke-width="15"/>
    <path d="M400 365V95" fill="none" stroke="#b78336" stroke-width="25" stroke-linecap="round"/>
    <path d="M400 355V110" fill="none" stroke="#f6e7ce" stroke-width="18" stroke-dasharray="4 9"/>
    <g class="map-buildings" fill="#fffaf2" stroke="#7a4b38" stroke-width="2">
      <rect x="338" y="57" width="124" height="70" rx="12"/><rect x="238" y="160" width="110" height="56" rx="12"/>
      <rect x="474" y="183" width="118" height="56" rx="12"/><rect x="550" y="285" width="110" height="56" rx="12"/>
      <rect x="106" y="262" width="110" height="56" rx="12"/><rect x="342" y="280" width="116" height="58" rx="12"/>
    </g>
    <g class="map-landmarks" font-family="system-ui, sans-serif" font-size="16" font-weight="700" text-anchor="middle" fill="#2f2924">
      <text x="400" y="87">北港朝天宮</text><text x="400" y="110" font-size="12" fill="#9f2f24">旅程中心點</text>
      <text x="293" y="194">北港工藝坊</text><text x="533" y="217">遊客中心</text>
      <text x="605" y="318">水道頭</text><text x="161" y="295">主要停車區</text><text x="400" y="315">中山路老街</text>
    </g>
    <g class="map-bridge" transform="translate(705 375)"><path d="M-68 22h136" stroke="#fff" stroke-width="8"/><path d="M-68 22 0-20l68 42" fill="none" stroke="#9f2f24" stroke-width="7"/><text y="50" text-anchor="middle" fill="#2f2924" font-family="system-ui" font-size="14" font-weight="700">女兒橋・北港溪</text></g>
    <g class="map-utility" transform="translate(315 110)"><circle r="15" fill="#42675d"/><text y="5" text-anchor="middle" fill="white" font-family="system-ui" font-size="13" font-weight="800">廁</text></g>
    <g class="map-utility" transform="translate(193 332)"><circle r="15" fill="#9f2f24"/><text y="5" text-anchor="middle" fill="white" font-family="system-ui" font-size="13" font-weight="800">P</text></g>
  </svg>
  <div class="map-note"><span>北 ↑</span><span>步行關係示意・非精確比例</span></div>
</div>

<style>
  .guide-map { overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--bg-warm); box-shadow: var(--shadow-lg); }
  .guide-map svg { width: 100%; }
  .map-note { display: flex; align-items: center; justify-content: space-between; padding: .65rem 1rem; color: var(--muted); background: var(--surface); font-size: .75rem; }
  .map-note span:first-child { color: var(--red); font-weight: 900; }
  .guide-map.interactive .map-landmarks, .guide-map.interactive .map-utility { opacity: .16; }
  .guide-map.interactive .map-bridge text { opacity: .28; }
  .guide-map.interactive .map-note { display: none; }
</style>
