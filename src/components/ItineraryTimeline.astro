---
import Icon from "./Icon.astro";
import type { Itinerary } from "../data/itineraries";
interface Props { itinerary: Itinerary }
const { itinerary } = Astro.props;
---
<div class="route-summary"><div><small>總時間</small><strong>{itinerary.duration}</strong></div><div><small>步行距離</small><strong>{itinerary.distance}</strong></div><div><small>節奏</small><strong>{itinerary.pace}</strong></div><div><small>適合</small><strong>{itinerary.audience}</strong></div></div>
<ol class="timeline">{itinerary.stops.map((stop, index) => <li><div class="time"><span>{stop.time}</span><i>{String(index+1).padStart(2,"0")}</i></div><article><div class="stop-head"><div><small>STOP {String(index+1).padStart(2,"0")}</small><h2>{stop.title}</h2></div><strong>停留 {stop.duration}</strong></div><dl><div><dt><Icon name="route" size={17}/>步行</dt><dd>{stop.walk}</dd></div><div><dt><Icon name="toilet" size={17}/>公廁</dt><dd>{stop.toilet}</dd></div><div><dt><Icon name="clock" size={17}/>休息</dt><dd>{stop.rest}</dd></div><div><dt><Icon name="umbrella" size={17}/>雨天</dt><dd>{stop.rain}</dd></div></dl></article></li>)}</ol>
<style>
  .route-summary { display: grid; grid-template-columns: repeat(4,1fr); margin-bottom: 3rem; border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; background: var(--surface); }.route-summary div { display: grid; min-height: 90px; align-content: center; padding: .8rem 1rem; border-right: 1px solid var(--border); }.route-summary div:last-child { border:0 }.route-summary small { color:var(--muted);font-size:.68rem}.route-summary strong{font-size:.84rem}.timeline{position:relative;list-style:none}.timeline::before{position:absolute;top:0;bottom:0;left:4.8rem;width:1px;background:var(--border);content:""}.timeline li{position:relative;display:grid;grid-template-columns:6.2rem 1fr;gap:1.2rem;padding-bottom:1.2rem}.time{z-index:1;display:grid;justify-items:start;align-content:start}.time>span{padding:.3rem .5rem;border-radius:.4rem;color:white;background:var(--ink);font-size:.72rem;font-weight:800}.time i{display:grid;width:2.6rem;height:2.6rem;margin:.7rem 0 0 3.5rem;border:1px solid var(--border);border-radius:50%;place-items:center;color:var(--red);background:var(--bg-paper);font-family:var(--serif);font-style:normal;font-size:.75rem}.timeline article{padding:1.3rem;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface);box-shadow:var(--shadow-sm)}.stop-head{display:flex;align-items:start;justify-content:space-between;gap:1rem}.stop-head small{color:var(--red);font-size:.65rem;font-weight:900;letter-spacing:.1em}.stop-head h2{margin:.25rem 0 0;font-size:1.45rem}.stop-head>strong{color:var(--green);font-size:.75rem}.timeline dl{display:grid;grid-template-columns:1fr 1fr;margin-top:1rem;border-top:1px solid var(--border)}.timeline dl div{padding:.7rem;border-bottom:1px solid var(--border)}.timeline dl div:nth-child(odd){border-right:1px solid var(--border)}.timeline dt{display:flex;align-items:center;gap:.35rem;color:var(--muted);font-size:.68rem}.timeline dd{margin:.25rem 0 0;font-size:.78rem;font-weight:700}
  @media(max-width:620px){.route-summary{grid-template-columns:1fr 1fr}.route-summary div:nth-child(2){border-right:0}.route-summary div:nth-child(-n+2){border-bottom:1px solid var(--border)}.timeline::before{left:1.2rem}.timeline li{grid-template-columns:2.5rem 1fr;gap:.7rem}.time>span{display:none}.time i{margin:0;width:2.4rem;height:2.4rem}.stop-head{flex-direction:column}.timeline dl{grid-template-columns:1fr}.timeline dl div:nth-child(odd){border-right:0}}
</style>
