---
import Breadcrumbs from "./Breadcrumbs.astro";
interface Props {
  title: string;
  eyebrow: string;
  description: string;
  breadcrumbs?: { label: string; href?: string }[];
  tone?: "red" | "green" | "gold" | "ink";
}
const { title, eyebrow, description, breadcrumbs = [{ label: "首頁", href: "/" }, { label: title }], tone = "red" } = Astro.props;
---
<header class:list={["page-hero", `tone-${tone}`]}>
  <div class="container hero-inner">
    <div class="hero-copy">
      <Breadcrumbs items={breadcrumbs}/>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      <p class="source-link"><a href="/editorial-policy/">查看資料來源與編輯原則 →</a></p>
    </div>
    <div class="hero-mark" aria-hidden="true"><span>北</span><i></i><small>23.568° N<br/>120.304° E</small></div>
  </div>
</header>

<style>
  .page-hero { position: relative; overflow: hidden; padding-block: clamp(3rem, 8vw, 6.5rem); border-bottom: 1px solid var(--border); }
  .page-hero::before { position: absolute; top: -10rem; right: -8rem; width: 32rem; height: 32rem; border: 1px solid rgba(122,75,56,.13); border-radius: 50%; content: ""; box-shadow: 0 0 0 3rem rgba(122,75,56,.04), 0 0 0 7rem rgba(122,75,56,.035); }
  .tone-red { --hero-accent: var(--red); background: linear-gradient(135deg, var(--bg-paper), #f0dfcc); }
  .tone-green { --hero-accent: var(--green); background: linear-gradient(135deg, var(--bg-paper), #dfe8df); }
  .tone-gold { --hero-accent: var(--gold); background: linear-gradient(135deg, var(--bg-paper), #f0e1bd); }
  .tone-ink { --hero-accent: var(--ink); background: linear-gradient(135deg, var(--bg-paper), #e6ded3); }
  .hero-inner { position: relative; display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 2rem; }
  .hero-copy { max-width: 800px; }
  .eyebrow { color: var(--hero-accent); }
  h1 { margin: .75rem 0 1rem; font-size: clamp(2.4rem, 6vw, 4.7rem); }
  .description { max-width: 700px; color: var(--muted); font-size: clamp(1rem, 2vw, 1.18rem); }
  .source-link { margin-top: 1.6rem; color: var(--hero-accent); font-size: .72rem; font-weight: 800; }
  .hero-mark { display: grid; width: 8.5rem; height: 8.5rem; border: 1px solid rgba(122,75,56,.24); border-radius: 50%; place-items: center; background: rgba(255,250,242,.45); }
  .hero-mark span { color: var(--hero-accent); font-family: var(--serif); font-size: 2.2rem; font-weight: 800; line-height: 1; }
  .hero-mark i { width: 1px; height: 1.3rem; margin-top: -.5rem; background: var(--hero-accent); }
  .hero-mark small { margin-top: -1rem; color: var(--muted); font-size: .55rem; line-height: 1.4; text-align: center; }
  @media (max-width: 700px) { .hero-inner { grid-template-columns: 1fr; }.hero-mark { display: none; } }
</style>
