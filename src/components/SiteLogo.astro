---
interface Props { compact?: boolean; inverse?: boolean }
const { compact = false, inverse = false } = Astro.props;
---
<a class:list={["logo", { compact, inverse }]} href="/" aria-label="北港老街指南首頁">
  <svg viewBox="0 0 64 58" aria-hidden="true">
    <path class="roof" d="M5 28h54L48 18l-7 4-9-18-9 18-7-4z" />
    <path class="house" d="M13 30v22h38V30M24 52V36h16v16" />
    <circle class="sun" cx="32" cy="43" r="3.5" />
  </svg>
  <span>
    <strong>北港老街</strong>
    <small>BEIGANG OLD STREET</small>
  </span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: .65rem; color: var(--ink); text-decoration: none; }
  .logo:hover { color: var(--red); }
  svg { width: 2.65rem; flex: 0 0 auto; }
  .roof { fill: var(--red); stroke: currentColor; stroke-width: 1.5; stroke-linejoin: round; }
  .house { fill: none; stroke: currentColor; stroke-width: 2.4; }
  .sun { fill: var(--gold); }
  span { display: grid; line-height: 1; }
  strong { font-family: var(--serif); font-size: 1.18rem; letter-spacing: .14em; }
  small { margin-top: .38rem; font-size: .51rem; font-weight: 800; letter-spacing: .15em; }
  .inverse { color: white; }
  .inverse .roof { fill: var(--gold-light); }
  .compact span { display: none; }
</style>
