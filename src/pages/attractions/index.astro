---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import StatusBadge from "../../components/StatusBadge.astro";
const attractions = (await getCollection("attractions")).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="北港景點指南｜朝天宮、老街、工藝坊與水道頭" description="整理北港朝天宮、老街、工藝坊、水道頭、女兒橋等景點的開放資訊、停留時間、交通與無障礙提醒。">
  <PageHero title="北港景點" eyebrow="PLACES TO VISIT" description="不把景點排成名次。先看停留時間、距離與開放狀態，再選出適合你今天步調的北港。" tone="gold" breadcrumbs={[{label:"首頁",href:"/"},{label:"景點"}]}/>
  <section class="section"><div class="container"><div class="intro"><p>第一次來，先走 <a href="/attractions/chaotian-temple/">朝天宮</a>、<a href="/attractions/beigang-old-street/">中山路老街</a>和<a href="/attractions/beigang-craft/">北港工藝坊</a>；有半天以上，再把水道頭與河岸放進行程。</p><span>{attractions.length} 個景點資料</span></div><div class="place-list">{attractions.map((place) => <a class="place-card" href={`/attractions/${place.id}/`}><div class="number">{String(place.data.order).padStart(2,"0")}</div><div class="main"><div><span>{place.data.categoryLabel}</span><StatusBadge status={place.data.status}/></div><h2>{place.data.title}</h2><p>{place.data.description}</p></div><dl><div><dt>停留</dt><dd>{place.data.recommendedDuration}</dd></div><div><dt>距朝天宮</dt><dd>{place.data.walkMinutesFromChaotianTemple === 0 ? "0 分" : `約 ${place.data.walkMinutesFromChaotianTemple} 分`}</dd></div><div><dt>門票</dt><dd>{place.data.admission}</dd></div></dl><i>→</i></a>)}</div></div></section>
</BaseLayout>
<style>
  .intro { display: flex; align-items: center; justify-content: space-between; gap: 2rem; margin-bottom: 2rem; }.intro p { max-width: 720px; color: var(--muted); }.intro a { color: var(--red); font-weight: 800; }.intro span { flex: 0 0 auto; padding: .35rem .8rem; border: 1px solid var(--border); border-radius: 999px; font-size: .75rem; font-weight: 800; }.place-list { border-top: 1px solid var(--border); }.place-card { position: relative; display: grid; grid-template-columns: 4rem 1.5fr 1fr auto; align-items: center; gap: 2rem; min-height: 190px; padding: 1.5rem 1rem; border-bottom: 1px solid var(--border); color: var(--ink); text-decoration: none; transition: background .2s, padding .2s; }.place-card:hover { padding-inline: 1.5rem; color: var(--ink); background: var(--surface); }.number { color: var(--gold); font-family: var(--serif); font-size: 1.2rem; }.main > div { display: flex; align-items: center; gap: .7rem; }.main > div > span { color: var(--red); font-size: .72rem; font-weight: 900; }.main h2 { margin: .5rem 0; font-size: 1.55rem; }.main p { color: var(--muted); font-size: .85rem; }.place-card dl { display: grid; gap: .45rem; }.place-card dl div { display: grid; grid-template-columns: 5rem 1fr; font-size: .78rem; }.place-card dt { color: var(--muted); }.place-card dd { margin: 0; font-weight: 700; }.place-card > i { color: var(--red); font-style: normal; font-size: 1.3rem; }
  @media(max-width: 800px) { .intro { align-items: flex-start; flex-direction: column; }.place-card { grid-template-columns: 3rem 1fr auto; gap: 1rem; }.place-card dl { display: none; }.main p { max-width: 520px; } }
  @media(max-width: 520px) { .place-card { grid-template-columns: 1fr auto; min-height: 0; }.number { display: none; }.main > div { align-items: flex-start; flex-direction: column; }.place-card > i { grid-column: 2; grid-row: 1; } }
</style>
