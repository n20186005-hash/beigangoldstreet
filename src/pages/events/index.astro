---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { events } from "../../data/events";
---
<BaseLayout title="北港活動｜燈會、迎媽祖、進香與交通管制" description="整理北港燈會、迎媽祖、進香季、藝閣及交通管制，分開說明活動內容與遊客應對方式。">
  <PageHero title="北港活動" eyebrow="EVENTS & PILGRIMAGE" description="活動介紹和遊客怎麼應對分開看。日期、管制與接駁每年都會調整，舊活動頁只保留記錄，不假裝仍在進行。" tone="red" breadcrumbs={[{label:"首頁",href:"/"},{label:"活動"}]}/>
  <section class="section"><div class="container"><div class="current"><div><span>CURRENT STATUS</span><h2>2026 迎媽祖活動已結束</h2><p>本站目前沒有可確認的常態大型管制。下一次節慶請等待主辦單位公布日期、停車與交通方案。</p></div><StatusBadge status="unknown" label="下屆待公告"/></div><div class="event-grid">{events.map((event,index)=><a href={`/events/${event.slug}/`}><span>{String(index+1).padStart(2,"0")}</span><small>{event.label}</small><h2>{event.title}</h2><p>{event.description}</p><div><strong>{event.status}</strong><i>查看遊客提醒 →</i></div></a>)}</div><div class="etiquette"><h2>遇到遶境，先做一個好旅客</h2><ul><li>不穿越神轎與儀仗</li><li>不阻擋店家、住家與救護動線</li><li>拍人物前先徵得同意</li><li>帶孩童與長輩遠離鞭炮密集處</li></ul></div></div></section>
</BaseLayout>
<style>.current{display:flex;align-items:center;justify-content:space-between;gap:2rem;padding:1.6rem;border-left:5px solid var(--gold);border-radius:0 var(--radius-md) var(--radius-md) 0;background:var(--surface);box-shadow:var(--shadow-sm)}.current span{color:var(--red);font-size:.66rem;font-weight:900;letter-spacing:.12em}.current h2{margin:.35rem 0;font-size:1.5rem}.current p{max-width:700px;color:var(--muted);font-size:.85rem}.event-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2rem}.event-grid>a{display:flex;min-height:320px;padding:1.4rem;border:1px solid var(--border);border-radius:var(--radius-md);color:var(--ink);background:var(--surface);flex-direction:column;text-decoration:none;transition:transform .2s,box-shadow .2s}.event-grid>a:hover{color:var(--ink);box-shadow:var(--shadow-lg);transform:translateY(-4px)}.event-grid>a>span{color:var(--gold);font-family:var(--serif)}.event-grid small{margin-top:2rem;color:var(--red);font-weight:900}.event-grid h2{margin:.4rem 0}.event-grid p{color:var(--muted);font-size:.84rem}.event-grid>a>div{display:flex;justify-content:space-between;gap:1rem;margin-top:auto;padding-top:1rem;border-top:1px solid var(--border);font-size:.72rem}.event-grid strong{color:var(--green)}.event-grid i{color:var(--red);font-style:normal;font-weight:900}.etiquette{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:3rem;margin-top:3rem;padding:2rem;border-radius:var(--radius-md);color:white;background:var(--ink)}.etiquette ul{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;list-style:none}.etiquette li{padding:.5rem;border-bottom:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.75);font-size:.8rem}@media(max-width:680px){.current{align-items:flex-start;flex-direction:column}.event-grid,.etiquette{grid-template-columns:1fr}.event-grid>a{min-height:280px}.etiquette{gap:1rem}.etiquette ul{grid-template-columns:1fr}}</style>
