---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { foodItems } from "../../data/food";
import { foodGuides } from "../../data/foodGuides";
export function getStaticPaths(){return foodGuides.map(guide=>({params:{slug:guide.slug},props:{guide}}));}
const { guide } = Astro.props;
const items = foodItems.filter(item => guide.names.includes(item.name));
---
<BaseLayout title={`${guide.title}｜時段、品項與行程安排｜北港老街指南`} description={guide.lead}>
  <PageHero title={guide.title} eyebrow={guide.eyebrow} description={guide.lead} tone="gold" breadcrumbs={[{label:"首頁",href:"/"},{label:"美食",href:"/food/"},{label:guide.title}]}/>
  <section class="section"><div class="container detail-grid"><article><p class="answer">{guide.answer}</p><h2>先認識這些品項</h2><div class="items">{items.map(item=><div><span>{item.category}・{item.style}</span><h3>{item.name}</h3><p>{item.description}</p><dl><div><dt>時段</dt><dd>{item.time}</dd></div><div><dt>預算</dt><dd>{item.budget}</dd></div><div><dt>用餐</dt><dd>{item.dine}</dd></div><div><dt>提醒</dt><dd>{item.soldOut}</dd></div></dl></div>)}</div><h2>怎麼安排比較順？</h2><ol>{guide.tips.map(tip=><li>{tip}</li>)}</ol><h2>營業時間可靠嗎？</h2><p>本站只記錄常見時段，不根據一般營業時間顯示「營業中」。店休、售完、節慶備料與臨時調整都可能發生，若只為一間店前往，請直接查店家當日公告。</p><h2>資料說明</h2><p>本頁是品項與行程指南，不構成店家排名，也不使用未經授權的點評網站評分。</p></article><aside><div class="aside-card"><h2>三個原則</h2><ul><li>早餐要早</li><li>午餐避尖峰</li><li>晚餐先確認</li></ul></div><div class="aside-card"><h2>繼續規劃</h2><a href="/opening-hours/">營業時段總覽 →</a><a href="/itineraries/">選擇遊覽路線 →</a><a href="/map/">打開美食地圖 →</a></div></aside></div></section>
</BaseLayout>
<style>.detail-grid{display:grid;grid-template-columns:minmax(0,1fr) 280px;align-items:start;gap:5rem}.detail-grid article{max-width:760px}.answer{padding:1.3rem;border-left:4px solid var(--gold);border-radius:0 var(--radius-md) var(--radius-md) 0;background:var(--surface);font-size:1.08rem}.detail-grid article>h2{margin:3.2rem 0 1rem}.items{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.items>div{padding:1.2rem;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface)}.items span{color:var(--red);font-size:.68rem;font-weight:900}.items h3{margin:.4rem 0}.items p{color:var(--muted);font-size:.82rem}.items dl{margin-top:1rem}.items dl div{display:grid;grid-template-columns:4rem 1fr;padding:.3rem 0;border-top:1px dashed var(--border);font-size:.7rem}.items dt{color:var(--muted)}.items dd{margin:0;font-weight:700}.detail-grid article>ol{padding-left:1.3rem}.detail-grid article>ol li{padding:.45rem 0;color:#514942}aside{position:sticky;top:7rem}.aside-card{padding:1.2rem;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface)}.aside-card+.aside-card{margin-top:1rem}.aside-card h2{margin-bottom:.7rem;font-family:var(--sans);font-size:.76rem;letter-spacing:.1em}.aside-card ul{padding-left:1rem}.aside-card li,.aside-card a{display:block;color:var(--muted);font-size:.8rem}.aside-card a{padding:.35rem 0;color:var(--red);font-weight:800}@media(max-width:800px){.detail-grid{grid-template-columns:1fr;gap:2rem}aside{position:static;display:grid;grid-template-columns:1fr 1fr;gap:1rem}.aside-card+.aside-card{margin-top:0}}@media(max-width:560px){.items,aside{grid-template-columns:1fr}}</style>
