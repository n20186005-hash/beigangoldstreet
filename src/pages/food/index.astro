---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { foodItems } from "../../data/food";
import { foodGuides } from "../../data/foodGuides";
const groups = ["早餐","午餐","下午茶","晚餐"];
---
<BaseLayout title="北港老街美食指南｜早餐、鴨肉飯與伴手禮" description="按早餐、午餐、下午茶與晚餐整理北港美食，包含煎盤粿、麵線糊、鴨肉飯、假魚肚、花生與漢餅。">
  <PageHero title="北港美食" eyebrow="EAT IN BEIGANG" description="不做沒有來源的必吃排名。按照時間、份量和行程來選，吃得到比排得多更重要。" tone="gold" breadcrumbs={[{label:"首頁",href:"/"},{label:"美食"}]}/>
  <section class="section"><div class="container"><nav class="food-nav" aria-label="美食主題">{foodGuides.map(g=><a href={`/food/${g.slug}/`}>{g.title}</a>)}</nav>{groups.map(group => { const items=foodItems.filter(item=>item.category===group); return <section class="food-group"><header><span>{group === "早餐" ? "07—10" : group === "午餐" ? "11—14" : group === "下午茶" ? "14—17" : "17—LATE"}</span><h2>{group}</h2><p>{group === "早餐" ? "早到是最重要的攻略" : group === "午餐" ? "避開 12 點尖峰會更從容" : group === "下午茶" ? "邊散步邊安排伴手禮" : "把範圍擴大，不只看老街"}</p></header><div class="food-cards">{items.map(item=><article><div><span>{item.style}</span><strong>{item.budget}</strong></div><h3>{item.name}</h3><p>{item.description}</p><dl><div><dt>常見時段</dt><dd>{item.time}</dd></div><div><dt>用餐方式</dt><dd>{item.dine}</dd></div><div><dt>售完提醒</dt><dd>{item.soldOut}</dd></div><div><dt>位置</dt><dd>{item.walk}</dd></div></dl><small>{item.verified}</small></article>)}</div></section>})}<div class="principle"><div><span>OUR RULE</span><h2>不引用評分，不虛構「在地人都推薦」</h2></div><p>我們記錄品項、時段、預算、用餐方式和資料限制。店家營業與售完時間仍以當日現場為準。</p></div></div></section>
</BaseLayout>
<style>.food-nav{display:flex;flex-wrap:wrap;gap:.6rem;margin-bottom:4rem}.food-nav a{padding:.5rem .8rem;border:1px solid var(--border);border-radius:999px;font-size:.78rem;font-weight:800;text-decoration:none;background:var(--surface)}.food-group{display:grid;grid-template-columns:220px 1fr;gap:2rem;padding:3rem 0;border-top:1px solid var(--border)}.food-group>header{position:sticky;top:7rem;align-self:start}.food-group header>span{color:var(--red);font-size:.7rem;font-weight:900;letter-spacing:.15em}.food-group h2{margin:.4rem 0}.food-group header p{color:var(--muted);font-size:.8rem}.food-cards{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.food-cards article{padding:1.2rem;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--surface)}.food-cards article>div{display:flex;justify-content:space-between;color:var(--red);font-size:.68rem;font-weight:900}.food-cards h3{margin:.55rem 0}.food-cards>article>p{min-height:74px;color:var(--muted);font-size:.82rem}.food-cards dl{margin-top:1rem;border-top:1px solid var(--border)}.food-cards dl div{display:grid;grid-template-columns:5.5rem 1fr;padding:.35rem 0;border-bottom:1px dashed var(--border);font-size:.7rem}.food-cards dt{color:var(--muted)}.food-cards dd{margin:0;font-weight:700}.food-cards article>small{display:block;margin-top:.7rem;color:var(--green);font-size:.65rem}.principle{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:3rem;margin-top:3rem;padding:2rem;border-radius:var(--radius-md);color:white;background:var(--red)}.principle span{color:var(--gold-light);font-size:.68rem;font-weight:900}.principle h2{margin-top:.4rem}.principle p{color:rgba(255,255,255,.8)}@media(max-width:820px){.food-group{grid-template-columns:1fr}.food-group>header{position:static}.food-cards{grid-template-columns:1fr 1fr}}@media(max-width:620px){.food-cards,.principle{grid-template-columns:1fr}.food-cards>article>p{min-height:0}.principle{gap:1rem}}</style>
