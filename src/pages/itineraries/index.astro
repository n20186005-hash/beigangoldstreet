---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { itineraries } from "../../data/itineraries";
---
<BaseLayout title="北港行程規劃｜2 小時、半日與一日遊路線" description="北港老街 2 小時、半日、一日、親子、長輩與攝影路線，含步行時間、公廁、休息點與雨天替代方案。">
  <PageHero title="北港行程" eyebrow="CHOOSE YOUR ROUTE" description="不追求塞滿景點。先選你有多少時間、同行者走多快，再把吃飯和廁所放進路線。" tone="green" breadcrumbs={[{label:"首頁",href:"/"},{label:"行程"}]}/>
  <section class="section"><div class="container"><div class="route-grid">{itineraries.map((route,index)=><a class="route-card" href={`/itineraries/${route.slug}/`}><div class="route-top"><span>{String(index+1).padStart(2,"0")}</span><small>{route.eyebrow}</small></div><h2>{route.shortTitle}</h2><p>{route.description}</p><dl><div><dt>時間</dt><dd>{route.duration}</dd></div><div><dt>步行</dt><dd>{route.distance}</dd></div><div><dt>適合</dt><dd>{route.audience}</dd></div></dl><i>查看時間軸 →</i></a>)}</div><div class="first"><div><span>第一次不知道選哪條？</span><h2>從半日經典路線開始</h2><p>早餐、朝天宮、老街、工藝坊與午餐，內容夠完整，也不會因為跨區移動太累。</p></div><a class="button button--light" href="/itineraries/first-visit/">第一次來北港怎麼逛</a></div></div></section>
</BaseLayout>
<style>.route-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.route-card{display:flex;min-height:340px;padding:1.3rem;border:1px solid var(--border);border-radius:var(--radius-md);color:var(--ink);background:var(--surface);flex-direction:column;text-decoration:none;transition:transform .2s,box-shadow .2s}.route-card:hover{color:var(--ink);box-shadow:var(--shadow-lg);transform:translateY(-5px)}.route-top{display:flex;justify-content:space-between}.route-top span{color:var(--gold);font-family:var(--serif)}.route-top small{color:var(--red);font-weight:900;letter-spacing:.1em}.route-card h2{margin:1.4rem 0 .7rem;font-size:1.45rem}.route-card>p{color:var(--muted);font-size:.82rem}.route-card dl{margin-top:auto;padding-top:1rem}.route-card dl div{display:grid;grid-template-columns:4rem 1fr;padding:.3rem 0;border-top:1px dashed var(--border);font-size:.72rem}.route-card dt{color:var(--muted)}.route-card dd{margin:0;font-weight:700}.route-card>i{margin-top:1rem;color:var(--red);font-style:normal;font-size:.78rem;font-weight:900}.first{display:flex;align-items:center;justify-content:space-between;gap:3rem;margin-top:3rem;padding:2.5rem;border-radius:var(--radius-md);color:white;background:var(--green)}.first span{color:var(--gold-light);font-size:.72rem;font-weight:900}.first h2{margin:.4rem 0}.first p{max-width:650px;color:rgba(255,255,255,.75)}@media(max-width:900px){.route-grid{grid-template-columns:1fr 1fr}}@media(max-width:620px){.route-grid{grid-template-columns:1fr}.first{align-items:flex-start;flex-direction:column;gap:1.5rem}}</style>
