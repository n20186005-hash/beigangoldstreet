---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { souvenirGuides } from "../../data/souvenirs";
---
<BaseLayout title="北港伴手禮｜麻油、花生與傳統糕餅" description="北港老街麻油、花生、麻荖與傳統漢餅選購指南，整理用途、保存、過敏原與攜帶提醒。"><PageHero title="北港伴手禮" eyebrow="TAKE BEIGANG HOME" description="不急著買最大盒。先試味道、看保存，再把北港的麻油香、花生與糕餅帶回家。" tone="gold" breadcrumbs={[{label:"首頁",href:"/"},{label:"伴手禮"}]}/><section class="section"><div class="container"><div class="gift-grid">{souvenirGuides.map((guide,index)=><a href={`/souvenirs/${guide.slug}/`}><span>{String(index+1).padStart(2,"0")}</span><small>{guide.eyebrow}</small><h2>{guide.title}</h2><p>{guide.description}</p><i>查看選購提醒 →</i></a>)}</div><div class="gift-note"><h2>買伴手禮的四個問題</h2><ol><li>今天吃還是送人？</li><li>要帶多久、需不需要冷藏？</li><li>有沒有花生、芝麻、蛋奶等過敏原？</li><li>大量購買能否宅配或指定取貨？</li></ol></div></div></section></BaseLayout>
<style>.gift-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.gift-grid a{display:flex;min-height:350px;padding:1.4rem;border:1px solid var(--border);border-radius:var(--radius-md);color:var(--ink);background:var(--surface);flex-direction:column;text-decoration:none}.gift-grid a:hover{color:var(--ink);box-shadow:var(--shadow-lg)}.gift-grid span{color:var(--gold);font-family:var(--serif)}.gift-grid small{margin-top:2rem;color:var(--red);font-weight:900}.gift-grid h2{margin:.5rem 0;font-size:1.5rem}.gift-grid p{color:var(--muted);font-size:.84rem}.gift-grid i{margin-top:auto;color:var(--red);font-style:normal;font-size:.78rem;font-weight:900}.gift-note{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:3rem;padding:2rem;border-radius:var(--radius-md);color:white;background:var(--green)}.gift-note ol{padding-left:1.2rem;color:rgba(255,255,255,.8);font-size:.85rem}@media(max-width:760px){.gift-grid{grid-template-columns:1fr}.gift-grid a{min-height:250px}.gift-note{grid-template-columns:1fr;gap:1rem}}</style>
